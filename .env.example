# Supabase Auth + Database
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Live market data on Vercel serverless API
# Recommended: put these in Vercel Settings > Environment Variables WITHOUT VITE_ prefix.
TWELVE_DATA_API_KEY=YOUR_TWELVE_DATA_API_KEY
BIST_GAS_URL=YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL

# Optional browser fallback / local-only values
VITE_BIST_GAS_URL=YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL
VITE_TWELVE_DATA_API_KEY=YOUR_LOCAL_DEV_ONLY_API_KEY
